{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "Business profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "idUpload": { "type": "string" },
        "description": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] }
      },
      "required": ["id", "name", "email", "verificationStatus"]
    },
    "Seeker": {
      "title": "Seeker",
      "description": "Job seeker profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "idUpload": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] }
      },
      "required": ["id", "name", "email", "verificationStatus"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "employmentType": { "type": "string" },
        "salary": { "type": "string" },
        "postedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Closed"] }
      },
      "required": ["id", "businessId", "title", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "Job application information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "businessId": { "type": "string" },
        "seekerId": { "type": "string" },
        "seekerName": { "type": "string" },
        "seekerContact": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Under Review", "Interview Scheduled", "Accepted", "Declined"] },
        "appliedAt": { "type": "string" }
      },
      "required": ["id", "jobId", "businessId", "seekerId", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Basic user profile for authentication",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["business", "seeker", "admin"] }
      },
      "required": ["id", "name", "email", "role"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "Security and audit logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["id", "action", "userId", "timestamp", "severity"]
    }
  },
  "firestore": {
    "businesses/{businessId}": {
      "schema": "Business",
      "description": "Collection of business profiles"
    },
    "seekers/{seekerId}": {
      "schema": "Seeker",
      "description": "Collection of seeker profiles"
    },
    "jobs/{jobId}": {
      "schema": "Job",
      "description": "Collection of job postings"
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "Collection of job applications"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Collection of security and audit logs"
    }
  }
}
