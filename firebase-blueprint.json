{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Basic user profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["business", "seeker", "admin"] }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Business": {
      "title": "Business",
      "description": "Employer/Business profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "idUpload": { "type": "string" },
        "description": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] }
      },
      "required": ["id", "name", "email", "address", "phone", "idUpload", "verificationStatus"]
    },
    "Seeker": {
      "title": "Seeker",
      "description": "Job seeker profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "idUpload": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] }
      },
      "required": ["id", "name", "email", "phone", "address", "idUpload", "verificationStatus"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "employmentType": { "type": "string" },
        "salary": { "type": "string" },
        "postedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Closed"] }
      },
      "required": ["id", "businessId", "businessName", "title", "description", "category", "location", "postedAt", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "Job application details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "businessId": { "type": "string" },
        "seekerId": { "type": "string" },
        "seekerName": { "type": "string" },
        "seekerContact": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Under Review", "Interview Scheduled", "Accepted", "Declined"] },
        "appliedAt": { "type": "string" }
      },
      "required": ["id", "jobId", "businessId", "seekerId", "seekerName", "status", "appliedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Employer profiles"
    },
    "/seekers/{seekerId}": {
      "schema": "Seeker",
      "description": "Seeker profiles"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Job postings"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job applications"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
